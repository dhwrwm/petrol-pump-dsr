generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum FuelGrade {
  PETROL
  DIESEL
  PREMIUM_PETROL
  CNG
}

enum ShiftStatus {
  OPEN
  CLOSED
  RECONCILED
}

enum PaymentMethod {
  CASH
  UPI
  CARD
  CREDIT
  FLEET_CARD
}

enum DocumentType {
  AADHAR
  PAN
  DRIVING_LICENSE
  OTHER
}

enum Role {
  MANAGER
  OWNER
  ADMIN
}

enum ProductType {
  MS
  HSD
  XP95
  OTHERS
}

model User {
  id            String    @id
  name          String
  email         String    @unique
  emailVerified Boolean   @default(false)
  image         String?
  role          Role      @default(MANAGER)
  stationId     String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  station       Station?  @relation(fields: [stationId], references: [id])
  sessions      Session[]
  accounts      Account[]
  shiftsOpened  Shift[]   @relation("ShiftOpenedBy")
  shiftsClosed  Shift[]   @relation("ShiftClosedBy")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Organization {
  id        String    @id @default(cuid())
  name      String
  gstin     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  stations  Station[]
}

model Station {
  id             String           @id @default(cuid())
  organizationId String
  name           String
  code           String           @unique
  address        String?
  shiftsPerDay   Int              @default(2)
  setupComplete  Boolean          @default(false)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  organization   Organization     @relation(fields: [organizationId], references: [id])
  users          User[]
  tanks          Tank[]
  dispensers     Dispenser[]
  shifts         Shift[]
  customers      CreditCustomer[]
  expenses       Expense[]
  employees      Employee[]
  fuelRates      FuelRate[]
}

model Tank {
  id          String              @id @default(cuid())
  stationId   String
  capacity    Decimal             @db.Decimal(12, 3)
  currentDip  Decimal             @default(0) @db.Decimal(12, 3)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  station     Station             @relation(fields: [stationId], references: [id])
  productType ProductType         @default(MS)

  nozzles Nozzle[]
}

model Dispenser {
  id        String    @id @default(cuid())
  stationId String
  companyName      String
  serialNo  String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  station   Station   @relation(fields: [stationId], references: [id])

  // Relations
  nozzles   Nozzle[]
}

model Nozzle {
  id          String         @id @default(cuid())
  nozzleNumber Int
  productType ProductType
  isActive     Boolean     @default(true)

  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt 

  calibrationRenewals CalibrationRenewal[]
  sales Sale[]

  //Foreign key to Tank
  tankId String
  tank   Tank      @relation(fields: [tankId], references: [id])

  //Foreign key to Dispenser
  dispenserId String
  dispenser    Dispenser   @relation(fields: [dispenserId], references: [id])

   @@unique([dispenserId, nozzleNumber])
  meterReadings MeterReading[]
}

model CalibrationRenewal {
  id        String    @id @default(cuid())
  nozzleId  String
  date      DateTime  @default(now())
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  supportingDocuments String[]

  nozzle    Nozzle    @relation(fields: [nozzleId], references: [id], onDelete: Cascade)
} 

model Shift {
  id          String       @id @default(cuid())
  stationId   String
  openedById  String
  closedById  String?
  status      ShiftStatus  @default(OPEN)
  openedAt    DateTime     @default(now())
  closedAt    DateTime?
  notes       String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  station            Station            @relation(fields: [stationId], references: [id])
  openedBy           User               @relation("ShiftOpenedBy", fields: [openedById], references: [id])
  closedBy           User?              @relation("ShiftClosedBy", fields: [closedById], references: [id])
  readings           MeterReading[]
  sales              Sale[]
  payments           Payment[]
  expenses           Expense[]
  nozzleAssignments  NozzleAssignment[]
}

model MeterReading {
  id           String    @id @default(cuid())
  shiftId      String
  openingMeter Decimal   @db.Decimal(14, 3)
  closingMeter Decimal?  @db.Decimal(14, 3)
  testingLiters Decimal  @default(0) @db.Decimal(12, 3)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  shift        Shift     @relation(fields: [shiftId], references: [id])

  nozzleId     String
  nozzle       Nozzle    @relation(fields: [nozzleId], references: [id])

  @@unique([shiftId, nozzleId])
  sales Sale[]
}

model Sale {
  id          String          @id @default(cuid())
  shiftId     String
  customerId  String?
  employeeId  String?
  liters      Decimal         @db.Decimal(12, 3)
  rate        Decimal         @db.Decimal(12, 2)
  amount      Decimal         @db.Decimal(12, 2)
  soldAt      DateTime        @default(now())
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  productType ProductType       @default(MS)

  shift       Shift           @relation(fields: [shiftId], references: [id])
  customer    CreditCustomer? @relation(fields: [customerId], references: [id])
  employee    Employee?       @relation(fields: [employeeId], references: [id])
  payments    Payment[]

  nozzleId     String
  nozzle       Nozzle    @relation(fields: [nozzleId], references: [id])

  meterReadingId String
  meterReading   MeterReading @relation(fields: [meterReadingId], references: [id])
}

model Payment {
  id        String        @id @default(cuid())
  shiftId   String
  saleId    String?
  method    PaymentMethod
  amount    Decimal       @db.Decimal(12, 2)
  reference String?
  paidAt    DateTime      @default(now())
  createdAt DateTime      @default(now())

  shift     Shift         @relation(fields: [shiftId], references: [id])
  sale      Sale?         @relation(fields: [saleId], references: [id])
}

model CreditCustomer {
  id          String    @id @default(cuid())
  stationId   String
  name        String
  phone       String?
  vehicleNo   String?
  creditLimit Decimal   @default(0) @db.Decimal(12, 2)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  station     Station   @relation(fields: [stationId], references: [id])
  sales       Sale[]
}

model Expense {
  id          String    @id @default(cuid())
  stationId   String
  shiftId     String?
  category    String
  description String?
  amount      Decimal   @db.Decimal(12, 2)
  spentAt     DateTime  @default(now())
  createdAt   DateTime  @default(now())

  station     Station   @relation(fields: [stationId], references: [id])
  shift       Shift?    @relation(fields: [shiftId], references: [id])
}

model Employee {
  id          String    @id @default(cuid())
  stationId   String
  name        String
  phone       String?
  designation String
  joinedAt    DateTime
  resignedAt  DateTime?
  salary      Decimal   @db.Decimal(10, 2)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  station       Station            @relation(fields: [stationId], references: [id])
  assignments   NozzleAssignment[]
  documents     EmployeeDocument[]
  salaryRecords SalaryRecord[]
  sales         Sale[]
}

model EmployeeDocument {
  id         String       @id @default(cuid())
  employeeId String
  type       DocumentType
  url        String
  fileName   String?
  createdAt  DateTime     @default(now())

  employee   Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}

model SalaryRecord {
  id         String   @id @default(cuid())
  employeeId String
  month      DateTime
  paid       Decimal  @db.Decimal(10, 2)
  advance    Decimal  @default(0) @db.Decimal(10, 2)
  deductions Decimal  @default(0) @db.Decimal(10, 2)
  note       String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, month])
}

model FuelRate {
  id            String      @id @default(cuid())
  stationId     String
  productType   ProductType
  rate          Decimal     @db.Decimal(12, 2)
  effectiveDate DateTime    @db.Date
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  station       Station     @relation(fields: [stationId], references: [id])

  @@unique([stationId, productType, effectiveDate])
}

model NozzleAssignment {
  id                String   @id @default(cuid())
  shiftId           String
  nozzleId          String
  employeeId        String
  shortageDeduction Decimal? @db.Decimal(10, 2)
  shortageReason    String?
  createdAt         DateTime @default(now())

  shift    Shift    @relation(fields: [shiftId], references: [id])
  employee Employee @relation(fields: [employeeId], references: [id])

  @@unique([shiftId, nozzleId, employeeId])
}
